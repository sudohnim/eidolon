# Eidolon configuration — copy to `.env` and fill in.
# Eidolon runs locally; nothing here leaves your machine.

# ── Required: local services ─────────────────────────────────────────────────
# Ollama serves the local LLM (narrative only). Install: https://ollama.com
#   ollama pull llama3.1:8b
OLLAMA_HOST=http://localhost:11434
# SpiderFoot provides broad footprinting. Run it locally (see README / Docker).
SPIDERFOOT_HOST=http://localhost:5001
SPIDERFOOT_TIMEOUT=600          # seconds to wait for a SpiderFoot scan

# ── Required: API keys ───────────────────────────────────────────────────────
HIBP_API_KEY=                   # haveibeenpwned.com/API/Key (paid)
APIFY_API_TOKEN=                # apify.com — powers broker scanning
APIFY_ACTOR_ID=                 # the Apify actor used for broker lookups
SCRAPFLY_API_KEY=               # scrapfly.io — scraping backend

# ── Optional: extra sources (each tool skips gracefully if unset) ────────────
SHODAN_API_KEY=                 # shodan.io — exposed-host intel
NUMVERIFY_API_KEY=              # numverify.com — phone intel (free: 100/month)
COURTLISTENER_API_TOKEN=        # courtlistener.com -> profile -> API (free)
OPENCORPORATES_API_KEY=         # opencorporates.com/api_access (free tier)
WHOXY_API_KEY=                  # whoxy.com — reverse WHOIS by email/name/company
DEHASHED_EMAIL=                 # dehashed.com account email
DEHASHED_API_KEY=               # dehashed.com API key (~$5/month) — leaked records

# ── Runtime ──────────────────────────────────────────────────────────────────
RESULTS_OUTPUT_PATH=output/
TEST_MODE=false                 # true = use fixtures, no network (for tests)
